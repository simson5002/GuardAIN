{
  "manifest_version": 3,
  "name": "GuardiAIN Security",
  "version": "1.0",
  "description": "AI-powered real-time threat and vulnerability mitigation.",
  "icons": {
    "128": "icon.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "notifications",
    "scripting",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "guardia_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Check GuardiAIN Status"
  }
}